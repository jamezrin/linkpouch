# stash-service env vars for running from IDE (debug mode)
# Copy to .env and adjust if needed

SPRING_PROFILES_ACTIVE=local

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=linkpouch
POSTGRES_USER=linkpouch
POSTGRES_PASSWORD=linkpouch_secret

REDIS_HOST=localhost
REDIS_PORT=6379

S3_ENDPOINT=http://localhost:8333
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=linkpouch-screenshots

SERVER_PORT=8081
BASE_URL=http://localhost:8080
SIGNATURE_MASTER_KEY=local-dev-key
INDEXER_CALLBACK_SECRET=local-dev-indexer-secret
