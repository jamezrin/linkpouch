# Copy this file to .env and fill in the values before running docker-compose.
# Docker Compose reads variables marked with ${VAR} directly from this file.

# ── Required secrets ──────────────────────────────────────────────────────────

# HMAC-SHA256 master key for signed stash URLs (required — no default in production)
SIGNATURE_MASTER_KEY=local-dev-key
# Shared secret between stash-service and indexer-service (required — no default in production)
INDEXER_CALLBACK_SECRET=local-dev-indexer-secret

# ── OAuth2 providers (leave empty to disable that provider) ───────────────────

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# ── AI features ───────────────────────────────────────────────────────────────

# Built-in OpenRouter API key powering the free included AI tier (optional)
AI_INCLUDED_API_KEY=
# AES-256-GCM key for encrypting user-provided AI API keys at rest (base64, 32 bytes)
# Generate with: openssl rand -base64 32
AI_ENCRYPTION_KEY=
# Custom system prompt override for AI summaries (optional)
AI_SYSTEM_PROMPT=

# ── Infrastructure (defaults match docker-compose) ────────────────────────────

SPRING_PROFILES_ACTIVE=local

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=linkpouch
POSTGRES_USER=linkpouch
POSTGRES_PASSWORD=linkpouch_secret

REDIS_HOST=localhost
REDIS_PORT=6379

S3_ENDPOINT=http://localhost:8333
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=linkpouch-screenshots

# ── Stash service (for IDE / local run outside Docker) ────────────────────────

SERVER_PORT=8081
BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000

# JWT expiry for account sessions in days (default: 30)
# LINKPOUCH_ACCOUNT_JWT_EXPIRY_DAYS=30
